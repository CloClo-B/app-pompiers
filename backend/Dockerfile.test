FROM python:3.12-slim

WORKDIR /app

# Copier et installer les dépendances
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Installer alembic globalement
RUN pip install alembic

# Copier le code
COPY . .

# Installer le package en mode editable
RUN pip install -e .

# Forcer le mode TESTING
ENV TESTING=true

# Vérifier que app est accessible
RUN python -c "import app.main; print('✅ app.main found!')"

# Lancer les tests par défaut
CMD ["pytest", "tests/", "-v", "--tb=short"]
