# ============ Token de l'utilisateur ==============

key_use=projet_Sprint3 #Genere la clé secrète à utiliser pour le token
algo_use="HS256" #Algorithme utilisé pour le token
time_token=8 #Temps en heures de validité du token de l'utilisateur


# =========== Noms d'utilisateur et mots de passe ============

# Variables pour le conteneur db.
POSTGRES_USER: fenalim
POSTGRES_PASSWORD: fenalim123
POSTGRES_DB: fenalim_db

# Variable pour le conteneur API.
DATABASE_URL: postgresql+psycopg2://fenalim:fenalim123@db:5432/fenalim_db

# Variables pour le conteneur pgadmin.
PGADMIN_DEFAULT_EMAIL: admin@fenalim.fr
PGADMIN_DEFAULT_PASSWORD: E03?M12/